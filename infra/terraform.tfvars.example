# Copy to terraform.tfvars and fill in real values. Do not commit terraform.tfvars.

location             = "eastus2"
resource_group_name  = "rg-ravpn-workshop"
vnet_address_space   = "10.100.0.0/16"

# FTDv Day-0 bootstrap.
ftdv_admin_password = "REPLACE-ME-strong-password"
ftdv_reg_key        = "REPLACE-ME-from-SCC"
ftdv_nat_id         = "REPLACE-ME-from-SCC"
ftdv_image_plan     = "ftdv-azure-byol"
ftdv_image_version  = "latest"

# ISE bootstrap.
ise_admin_password = "REPLACE-ME-strong-password"
ise_dns_domain     = "ravpn.local"
ise_image_plan     = "cisco-ise_3_4"
ise_image_version  = "latest"

# Trading app VM admin.
app_admin_username       = "appadmin"
app_admin_ssh_public_key = "ssh-ed25519 AAAA... your-public-key"
